# ===== private-kb 环境变量 =====
# 复制为 .env 并填写。生产用 1Panel/.env 注入。

# ---- Postgres (pgvector + pg_trgm) ----
DATABASE_URL=postgres:///private_kb
# 或带认证：postgres://kb:kb@127.0.0.1:5432/private_kb

# ---- Redis（异步摄入队列）----
REDIS_URL=redis://127.0.0.1:6379/0

# ---- 服务 ----
PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-please-32-chars-min!!
JWT_TTL=7d

# ---- Chat: DeepSeek 官方（reasoning 模型，支持 function calling）----
# 模型名：deepseek-v4-pro 或 deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com/v1
CHAT_API_KEY=sk-xxxxxxxxxxxxxxxx
CHAT_MODEL=deepseek-v4-pro

# ---- Embedding: 智谱 embedding-3（官方文档 bigmodel.cn）----
# 默认 2048 维，必须显式指定 dimensions=1024（与建表 vector(1024) 对齐）
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=xxxxxxxx.xxxxxxxxxxxxxxxx
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=1024

# ---- 扫描件 OCR: 智谱 GLM-OCR（layout_parsing 直连）----
GLM_OCR_API_KEY=
GLM_OCR_MODEL=glm-ocr

# ---- 存储 ----
UPLOAD_DIR=./data/uploads
CHUNK_DIR=./data/chunks

# ---- 摄入并发 ----
EMBED_CONCURRENCY=5
OCR_CHUNK_PAGES=100

# ---- 加密 ----
# 用户绑定的 Chat key 用此密钥 AES-256-GCM 加密入库（生产务必改，≥32 字符）
ENC_KEY=change-me-please-32-chars-min!!
