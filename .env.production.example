# ===== 生产环境变量模板 =====
# 复制为 .env.production 并填写真实值。绝不提交到 git。

# PostgreSQL
PG_USER=kb
PG_PASSWORD=<生成强密码>
PG_DB=private_kb

# JWT + 加密（必须 32 字符以上）
JWT_SECRET=<生成 64 字符随机串>
ENC_KEY=<生成 64 字符随机串>

# DeepSeek Chat
CHAT_BASE_URL=https://api.deepseek.com/v1
CHAT_API_KEY=sk-xxxxxxxxxxxxxxxx
CHAT_MODEL=deepseek-v4-pro

# 智谱 Embedding
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=xxxxxxxx.xxxxxxxxxxxxxxxx
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=1024

# 前端 CORS
CORS_ORIGIN=https://your-domain.com

# 限流（每分钟）
RATE_LIMIT=200
