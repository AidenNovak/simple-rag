{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "server",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "allowImportingTsExtensions": false,
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["server/src/*"]
    }
  },
  "include": ["server/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "web"]
}
